{
  "rules": {
    "touch_hold_frames": 2,
    "lift_hold_frames": 2,
    "wrist_to_surface_margin": 30.0,
    "wrist_to_bottom_margin": 40.0,
    "min_wrist_confidence": 0.3,
    "min_shoulder_confidence": 0.3,
    "min_hip_confidence": 0.3,
    "lift_ratio_threshold": 0.1
  },
  "multi_camera_inference": {
    "pose_model_path": "yolo26n-pose.pt",
    "person_model_path": null,
    "seat_model_path": null,
    "output_json_path": "outputs/multi_camera_action_results.json",
    "output_video_path": "outputs/multi_camera_action_preview.mp4",
    "confidence": 0.25,
    "iou": 0.45,
    "device": "cpu",
    "save_visualization": true,
    "show_window": true,
    "window_name": "seat-inspection-multi",
    "window_wait_ms": 1,
    "exit_key": "q",
    "max_consecutive_read_failures": 3,
    "min_active_cameras": 2,
    "fusion": {
      "default_action_strategy": "any",
      "touch_action_strategy": "any",
      "lift_action_strategy": "majority",
      "time_tolerance_ms": 120.0
