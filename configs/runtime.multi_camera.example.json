{
  "rules": {
    "touch_hold_frames": 2,
    "lift_hold_frames": 2,
    "wrist_to_surface_margin": 30.0,
    "wrist_to_bottom_margin": 40.0,
    "min_wrist_confidence": 0.3,
    "min_shoulder_confidence": 0.3,
    "min_hip_confidence": 0.3,
    "lift_ratio_threshold": 0.1
  },
  "multi_camera_inference": {
    "pose_model_path": "yolo26n-pose.pt",
    "person_model_path": null,
    "seat_model_path": null,
    "output_json_path": "outputs/multi_camera_action_results.json",
    "output_video_path": "outputs/multi_camera_action_preview.mp4",
    "confidence": 0.25,
    "iou": 0.45,
    "device": "cpu",
    "save_visualization": true,
    "show_window": true,
    "window_name": "seat-inspection-multi",
    "window_wait_ms": 1,
    "exit_key": "q",
    "fusion": {
      "default_action_strategy": "any",
      "touch_action_strategy": "any",
      "lift_action_strategy": "majority",
      "time_tolerance_ms": 120.0
    },
    "state_machine": {
      "enabled": true,
      "require_all_steps": true,
      "ok_label": "OK",
      "ng_label": "NG",
      "steps": [
        {
          "name": "touch_side",
          "action": "touch_side_surface",
          "min_frames": 2
        },
        {
          "name": "lift_bottom",
          "action": "lift_seat_bottom",
          "min_frames": 2
        }
      ]
    },
    "cameras": [
      {
        "name": "front",
        "source": "mvs://0?timeout_ms=1000",
        "seat_regions": {
          "overall": {
            "x1": 100,
            "y1": 100,
            "x2": 300,
            "y2": 320
          },
          "side_surface": {
            "x1": 280,
            "y1": 130,
            "x2": 330,
            "y2": 260
          },
          "bottom_surface": {
            "x1": 140,
            "y1": 220,
            "x2": 260,
            "y2": 330
          }
        }
      },
      {
        "name": "side",
        "source": "mvs://1?timeout_ms=1000",
        "seat_regions": {
          "overall": {
            "x1": 80,
            "y1": 90,
            "x2": 260,
            "y2": 320
          },
          "side_surface": {
            "x1": 210,
            "y1": 120,
            "x2": 280,
            "y2": 250
          },
          "bottom_surface": {
            "x1": 100,
            "y1": 220,
            "x2": 220,
            "y2": 340
          }
        }
      }
    ]
  }
}
